# Database
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require&uselibpqcompat=true"

# NextAuth
AUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Meta/Facebook OAuth
AUTH_META_ID=""
AUTH_META_SECRET=""

# GitHub OAuth
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Upstash Redis (optional - rate limiting will use in-memory if not set)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend (for Newsletter and notifications - optional)
RESEND_API_KEY=""
ADMIN_EMAIL="admin@example.com"

# Uploadthing (for image uploads - optional)
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# MeiliSearch (for advanced search - optional)
MEILISEARCH_HOST=""
MEILISEARCH_API_KEY=""

# Analytics (Plausible - optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""